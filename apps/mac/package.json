{
  "name": "@md-view/mac",
  "version": "0.1.0",
  "private": true,
  "description": "md.view — Markdown viewer for macOS",
  "author": "Peter <peab@peab.at>",
  "main": "dist-electron/main/index.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder --mac --config electron-builder.yml",
    "build:dir": "vite build && electron-builder --mac --dir --config electron-builder.yml"
  },
  "dependencies": {
    "@md-view/core": "*",
    "@md-view/ui": "*",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
